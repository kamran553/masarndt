# Copy this file to .env and fill in real values.

# MongoDB connection string (MongoDB Atlas or local instance)
MONGODB_URI=mongodb://127.0.0.1:27017/masar-ndt

# Port the Express API server listens on
PORT=5000

# Comma-separated list of allowed origins for CORS (your deployed frontend URL)
CLIENT_ORIGIN=http://localhost:5173

# SMTP Gmail configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Gmail credentials (use App Password from Google Account Security, NOT standard password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Recipient email where contact form notifications will be sent
SMTP_TO=receiver-email@example.com

